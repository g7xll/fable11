[
  {
    "name": "sidebar-collapse",
    "trigger": "button:has(svg[viewBox=\"0 0 16 14\"])",
    "before": {
      "groupAttrs": [],
      "asideVisible": true,
      "menus": [],
      "openMenus": 0
    },
    "after": {
      "groupAttrs": [
        "data-sidebar-collapsed"
      ],
      "asideVisible": false,
      "menus": [],
      "openMenus": 0
    },
    "note": "toggles data-sidebar-collapsed on .group; aside hides, content margin removed"
  },
  {
    "name": "account-dropdown",
    "trigger": "button:has-text(\"Account\")",
    "before": {
      "groupAttrs": [
        "data-sidebar-collapsed"
      ],
      "asideVisible": false,
      "menus": [],
      "openMenus": 0
    },
    "after": {
      "groupAttrs": [
        "data-sidebar-collapsed"
      ],
      "asideVisible": false,
      "menus": [
        {
          "hidden": false,
          "display": "block"
        }
      ],
      "openMenus": 1
    },
    "note": "opens role=menu panel (Settings/Support/Sign out); data-focus item highlights blue-500/white; esc/outside closes"
  },
  {
    "name": "video-miniplayer-dock",
    "trigger": "play video + scroll off-screen",
    "after": {
      "groupData": [
        "data-sidebar-collapsed"
      ]
    },
    "note": "video docks to fixed bottom-right mini-player when off-screen while playing (data-offscreen + data-playing)"
  },
