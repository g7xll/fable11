</a>  </div> </section> </main>  <script type="module">
  import KeenSlider from "https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/+esm";
  const keenSlider = new KeenSlider(
    "#testimonials-slider",
    {
      loop: true,
      slides: {
        origin: "center",
        perView: 1.5,
        spacing: 8,
      },
      breakpoints: {
        "(min-width: 1024px)": {
          slides: {
            origin: "center",
            perView: 3.2,
            spacing: 16,
          },
        },
      },
    },
    []
  );
  const keenSliderPrevious = document.getElementById("testimonials-previous");
  const keenSliderNext = document.getElementById("testimonials-next");
  keenSliderPrevious.addEventListener("click", () => keenSlider.prev());
  keenSliderNext.addEventListener("click", () => keenSlider.next());
</script> </body></html>