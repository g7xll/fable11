</main><!-- FuseJS: https://fusejs.io/ --><script type="module" src="/_astro/FuseJS.astro_astro_type_script_index_0_lang.szKh-OPk.js"></script><!-- Scripts --><script type="module">document.addEventListener(`DOMContentLoaded`,()=>{let e=document.getElementById(`playPauseBtn`),t=document.getElementById(`audioElement`),n=document.getElementById(`seekBar`),r=document.getElementById(`muteBtn`),i=document.getElementById(`backwardBtn`),a=document.getElementById(`forwardBtn`),o=document.getElementById(`currentTime`),s=document.getElementById(`duration`),c=document.getElementById(`playIcon`),l=document.getElementById(`pauseIcon`),u=document.getElementById(`speakerIcon`),d=document.getElementById(`muteIcon`);e.addEventListener(`click`,()=>{t.paused?(t.play(),c.classList.add(`hidden`),l.classList.remove(`hidden`)):(t.pause(),l.classList.add(`hidden`),c.classList.remove(`hidden`))}),r.addEventListener(`click`,()=>{t.muted=!t.muted,u.classList.toggle(`hidden`,t.muted),d.classList.toggle(`hidden`,!t.muted)}),i.addEventListener(`click`,()=>{t.currentTime=Math.max(0,t.currentTime-10)}),a.addEventListener(`click`,()=>{t.currentTime=Math.min(t.duration,t.currentTime+10)}),t.addEventListener(`timeupdate`,()=>{n.value=t.currentTime/t.duration*100;let e=Math.floor(t.currentTime/60),r=Math.floor(t.currentTime%60);o.textContent=`${String(e).padStart(2,`0`)}:${String(r).padStart(2,`0`)}`}),t.addEventListener(`loadedmetadata`,()=>{let e=Math.floor(t.duration/60),n=Math.floor(t.duration%60);s.textContent=`${String(e).padStart(2,`0`)}:${String(n).padStart(2,`0`)}`}),n.addEventListener(`input`,()=>{t.currentTime=n.value/100*t.duration})});</script></body></html>