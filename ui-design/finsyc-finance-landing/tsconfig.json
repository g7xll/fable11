{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",

		"strict": true,
		// The Finsyc template components are applied verbatim per the prompt's
		// "keep every component file's CODE 100% IDENTICAL" rule. A few of them
		// carry intentional unused identifiers (e.g. an imported React under the
		// react-jsx runtime, an unused `brandName` prop). These two checks are
		// therefore relaxed at the config level so the verbatim code compiles
		// cleanly without editing any component body. `strict` stays on.
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noFallthroughCasesInSwitch": true,

		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src", "vite.config.ts"]
}
