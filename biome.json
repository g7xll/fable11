{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"maxSize": 5242880,
		"includes": [
			"**",
			"!**/*.svg",
			"!**/.reference/**",
			"!**/assets/main.css",
			"!**/assets/css/tailwind.css",
			"!**/assets/css/studio.css",
			"!templates/premium/lexingtonthemes/spaziobianco/assets/css/button.css",
			"!templates/premium/lexingtonthemes/sandstone/**/*.html",
			"!templates/premium/lexingtonthemes/hirewise/styles.css"
		]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"html": {
		"formatter": {
			"enabled": true
		}
	}
}
