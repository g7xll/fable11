{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    // The shadcn drop-in at src/components/ui/radial-shader.tsx is copy-pasted
    // VERBATIM from the brief (the "copy-paste into components/ui" model). It is
    // intentionally left byte-for-byte unedited, so this project relaxes the few
    // checks that the third-party source trips rather than touching it:
    //   • noUnusedLocals       — its `import React` is JSX-only (never referenced)
    //   • strictNullChecks     — its `gl` handle is guarded with `if (!gl) return`
    //                            but read inside a hoisted `tick()` closure that
    //                            TS can't see the narrowing through.
    // Everything else stays strict, and this repo's own showcase code (App, hooks,
    // helpers) is written to be null-safe regardless of the flag.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
